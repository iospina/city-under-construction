# ---------------------------------------------------------------------------
# City Permits environment variables
#
# Copy to .env.local for development. Production values live in Vercel.
# .env.local is gitignored.
# ---------------------------------------------------------------------------

# --- Server-side ----------------------------------------------------------

# Neon connection string. Get it from your Neon project dashboard →
# Connection Details. Use the "pooled" connection string for serverless.
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require

# Required for /api/cron/sync-permits to authenticate the cron call. Generate
# a long random value and set the same string in Vercel project env vars.
#   openssl rand -hex 32
CRON_SECRET=

# Optional. Removes rate limiting on DOB NOW fetches during sync. Get one at
# https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# --- Client-side (Vite) ---------------------------------------------------

VITE_MAPBOX_ACCESS_TOKEN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
